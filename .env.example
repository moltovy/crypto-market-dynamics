# Copy this file to `.env` and fill in values. `.env` is gitignored.

# --- FRED (Federal Reserve Economic Data) - required for tools/data_collection/fetch_fred.py
FRED_API_KEY=

# --- DefiLlama - optional (public endpoints work without a key; Pro endpoints require one)
DEFILLAMA_API_KEY=
DEFILLAMA_USE_PRO=false
DEFILLAMA_RATE_LIMIT_SLEEP_SECONDS=0.25

# --- CoinMarketCap - optional, required only for CMC Fear & Greed history
CMC_API_KEY=

# --- Market-structure extension defaults
DATA_CACHE_DIR=data_cache
MARKET_STRUCTURE_START_DATE=2020-01-01
MARKET_STRUCTURE_END_DATE=2026-06-18
MARKET_STRUCTURE_CACHE_ONLY=false
MARKET_STRUCTURE_DRY_RUN=false
BINANCE_TOP_UNIVERSE_SIZE=100
BINANCE_RATE_LIMIT_SLEEP_SECONDS=0.10

# --- CryptoQuant - reserved for future rehydration use
# CRYPTOQUANT_API_KEY=

# --- Artemis - reserved for future rehydration use
# ARTEMIS_API_KEY=
