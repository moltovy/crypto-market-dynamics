# Copy this file to `.env` and fill in values. `.env` is gitignored.

# --- FRED (Federal Reserve Economic Data) — required for tools/data_collection/fetch_fred.py
FRED_API_KEY=

# --- DefiLlama — optional (public endpoints work without a key; enterprise endpoints require one)
DEFILLAMA_API_KEY=

# --- CryptoQuant — required if you plan to rehydrate the on-chain panel (reserved for future use)
# CRYPTOQUANT_API_KEY=

# --- Artemis — required if you plan to refresh the Artemis panel (reserved for future use)
# ARTEMIS_API_KEY=
