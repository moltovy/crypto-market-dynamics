reports/panels/*.parquet
reports/panels/**/*.parquet

# Ad-hoc exports
tmp/
*.tmp

# --- Never commit secrets or API-key material
*.key
*.pem
secrets/

# --- Third-party reference dumps (keep out of GitHub)
references/
